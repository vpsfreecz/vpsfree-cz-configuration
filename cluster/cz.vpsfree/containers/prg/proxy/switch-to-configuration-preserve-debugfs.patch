@@ -1238,0 +1257,35 @@ fn collect_unit_changes(
+            let preserve_debugfs_mount = if scope == UnitScope::System
+                && unit == "sys-kernel-debug.mount"
+                && unit_state.state == "active"
+                && unit_state.substate == "mounted"
+            {
+                let current_state = unit_file_state(&current_base_unit_file)?;
+                let new_state = unit_file_state(&new_base_unit_file)?;
+
+                if current_state == UnitFileState::Masked && new_state == UnitFileState::Masked {
+                    let source_path: String = unit_state
+                        .proxy
+                        .get("org.freedesktop.systemd1.Unit", "SourcePath")
+                        .with_context(|| format!("Failed to get SourcePath for {unit}"))?;
+
+                    preserve_host_provided_debugfs_mount(
+                        scope,
+                        unit,
+                        &unit_state.state,
+                        &unit_state.substate,
+                        &source_path,
+                        &current_state,
+                        &new_state,
+                    )
+                } else {
+                    false
+                }
+            } else {
+                false
+            };
+
+            if preserve_debugfs_mount {
+                log::debug!("preserving host-provided active mount {unit}");
+                continue;
+            }
