@@ -2777,0 +2831,101 @@
+    #[test]
+    fn preserve_host_provided_debugfs_mount() {
+        use super::{preserve_host_provided_debugfs_mount, UnitFileState, UnitScope};
+
+        let preserve = preserve_host_provided_debugfs_mount;
+
+        assert!(preserve(
+            UnitScope::System,
+            "sys-kernel-debug.mount",
+            "active",
+            "mounted",
+            "/proc/self/mountinfo",
+            &UnitFileState::Masked,
+            &UnitFileState::Masked,
+        ));
+
+        for (scope, unit, state, substate, source_path) in [
+            (
+                UnitScope::User,
+                "sys-kernel-debug.mount",
+                "active",
+                "mounted",
+                "/proc/self/mountinfo",
+            ),
+            (
+                UnitScope::System,
+                "other.mount",
+                "active",
+                "mounted",
+                "/proc/self/mountinfo",
+            ),
+            (
+                UnitScope::System,
+                "sys-kernel-debug.mount",
+                "activating",
+                "mounting",
+                "/proc/self/mountinfo",
+            ),
+            (
+                UnitScope::System,
+                "sys-kernel-debug.mount",
+                "inactive",
+                "dead",
+                "/proc/self/mountinfo",
+            ),
+            (
+                UnitScope::System,
+                "sys-kernel-debug.mount",
+                "active",
+                "dead",
+                "/proc/self/mountinfo",
+            ),
+            (
+                UnitScope::System,
+                "sys-kernel-debug.mount",
+                "active",
+                "mounted",
+                "",
+            ),
+            (
+                UnitScope::System,
+                "sys-kernel-debug.mount",
+                "active",
+                "mounted",
+                "/run/systemd/generator/sys-kernel-debug.mount",
+            ),
+        ] {
+            assert!(!preserve(
+                scope,
+                unit,
+                state,
+                substate,
+                source_path,
+                &UnitFileState::Masked,
+                &UnitFileState::Masked,
+            ));
+        }
+
+        let states = [
+            UnitFileState::Present,
+            UnitFileState::Masked,
+            UnitFileState::Missing,
+        ];
+        for current_state in &states {
+            for new_state in &states {
+                assert_eq!(
+                    preserve(
+                        UnitScope::System,
+                        "sys-kernel-debug.mount",
+                        "active",
+                        "mounted",
+                        "/proc/self/mountinfo",
+                        current_state,
+                        new_state,
+                    ),
+                    current_state == &UnitFileState::Masked && new_state == &UnitFileState::Masked,
+                );
+            }
+        }
+    }
+
