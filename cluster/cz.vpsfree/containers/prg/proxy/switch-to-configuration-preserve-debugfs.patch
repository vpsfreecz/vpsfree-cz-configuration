@@ -1130,0 +1131,18 @@ fn unit_file_state(unit_file: impl AsRef<Path>) -> Result<UnitFileState> {
+fn preserve_host_provided_debugfs_mount(
+    scope: UnitScope,
+    unit: &str,
+    state: &str,
+    substate: &str,
+    source_path: &str,
+    current_unit_file_state: &UnitFileState,
+    new_unit_file_state: &UnitFileState,
+) -> bool {
+    scope == UnitScope::System
+        && unit == "sys-kernel-debug.mount"
+        && state == "active"
+        && substate == "mounted"
+        && source_path == "/proc/self/mountinfo"
+        && current_unit_file_state == &UnitFileState::Masked
+        && new_unit_file_state == &UnitFileState::Masked
+}
